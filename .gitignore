node_modules/
dist/
.env
*.log
.DS_Store
# SQLite database and its WAL/shared-memory sidecars. These are runtime state
# (and can hold real user rows) — never commit them.
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db-journal

# demo audio/video working files (binary, not committed) — keep the tooling,
# ignore the media. `demo/*` (not `demo/`) so the negations below can apply.
demo/*
!demo/mux.sh
!demo/vo/
demo/vo/*
!demo/vo/.gitkeep
